{
  "name": "factorymind-mysql-cdc",
  "config": {
    "connector.class": "io.debezium.connector.mysql.MySqlConnector",
    "database.hostname": "mysql.factorymind.svc",
    "database.port": "3306",
    "database.user": "debezium",
    "database.password": "${file:/secrets/debezium-mysql.password:password}",
    "database.server.id": "184054",
    "topic.prefix": "factorymind.mysql",
    "schema.history.internal.kafka.bootstrap.servers": "kafka.factorymind.svc:9092",
    "schema.history.internal.kafka.topic": "factorymind.mysql.schema-history"
  }
}
