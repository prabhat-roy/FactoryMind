{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factorymind.io/events/iiot.machine.alarm.v1.json",
  "title": "MachineAlarm",
  "description": "Shop-floor machine alarm event published to MQTT topic factorymind/iiot/{site}/{equipment}/alarm",
  "type": "object",
  "required": ["event_id", "equipment_id", "severity", "code", "message", "ts"],
  "properties": {
    "event_id": {"type": "string", "format": "uuid"},
    "equipment_id": {"type": "string"},
    "site_id": {"type": "string"},
    "severity": {"type": "string", "enum": ["INFO", "WARNING", "ALARM", "CRITICAL"]},
    "code": {"type": "string"},
    "message": {"type": "string"},
    "ts": {"type": "string", "format": "date-time"},
    "ack_required": {"type": "boolean", "default": false}
  }
}
