{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factorymind.io/events/iiot.sensor.reading.v1.json",
  "title": "SensorReading",
  "type": "object",
  "required": ["equipment_id", "sensor_id", "metric", "value", "ts"],
  "properties": {
    "equipment_id": {"type": "string"},
    "sensor_id": {"type": "string"},
    "metric": {"type": "string"},
    "value": {"type": "number"},
    "uom": {"type": "string"},
    "quality": {"type": "integer", "minimum": 0, "maximum": 255},
    "ts": {"type": "string", "format": "date-time"}
  }
}
